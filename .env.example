# ============================================
# WhatsApp Meta Cloud API
# ============================================
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=mi_token_secreto
WHATSAPP_APP_SECRET=
WHATSAPP_REQUIRE_SIGNATURE=true
WHATSAPP_ALLOW_UNSIGNED_DEV_WEBHOOKS=false
WHATSAPP_MAX_AUDIO_BYTES=16777216
WHATSAPP_MAX_IMAGE_BYTES=10485760
WHATSAPP_ALLOWED_AUDIO_MIME_TYPES=audio/ogg,audio/opus,audio/mpeg,audio/mp4,audio/aac,audio/amr
WHATSAPP_ALLOWED_IMAGE_MIME_TYPES=image/jpeg,image/png,image/webp
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_API_BASE_URL=https://api.telegram.org
ALLOWED_TELEGRAM_CHAT_IDS=
TELEGRAM_MAX_AUDIO_BYTES=16777216
TELEGRAM_MAX_IMAGE_BYTES=10485760
TELEGRAM_ALLOWED_AUDIO_MIME_TYPES=audio/ogg,audio/opus,audio/mpeg,audio/mp4,audio/aac
TELEGRAM_ALLOWED_IMAGE_MIME_TYPES=image/jpeg,image/png,image/webp

# ============================================
# Google Sheets (solo para importación legacy)
# ============================================
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/service_account.json
GOOGLE_SPREADSHEET_ID=

# ============================================
# LLM Parser (proveedor intercambiable)
# ============================================
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
RECEIPT_OCR_PROVIDER=gemini
RECEIPT_OCR_MODEL=
RECEIPT_OCR_AUTO_CONFIDENCE=0.85
RECEIPT_OCR_CONFIRM_CONFIDENCE=0.60
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1

# ============================================
# Database
# Compatible con local Postgres o Render Postgres
# Si pegas una URL `postgresql://` o `postgres://`, la app la normaliza a asyncpg
# La base guarda timestamps en UTC.
# Para la URL interna de Render, DATABASE_USE_SSL suele quedar en false.
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/finance_bot
DATABASE_TIMEZONE=UTC
DATABASE_USE_SSL=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=1800

# ============================================
# App
# ============================================
DEFAULT_CURRENCY=ARS
GROUP_BOT_MENTION=@anotamelo
ALLOWED_PHONE_NUMBERS=
# Planes: FREE tiene hasta 5 audios por semana y 3 reportes por mes; PREMIUM queda ilimitado.
# El rate limit actual usa cache local por proceso, no Redis.
WHATSAPP_RATE_LIMIT_ENABLED=true
WHATSAPP_RATE_LIMIT_MAX_MESSAGES=8
WHATSAPP_RATE_LIMIT_WINDOW_SECONDS=60
WHATSAPP_RATE_LIMIT_NOTIFY_COOLDOWN_SECONDS=120
LLM_TIMEOUT_SECONDS=5
LOG_LEVEL=INFO

# ============================================
# Transcription (Groq Whisper)
# ============================================
GROQ_API_KEY=
TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# ============================================
# Agente
# ============================================
CONVERSATION_TTL_MINUTES=60
MAX_AGENT_ITERATIONS=10
MONTHLY_INFLATION_RATE=0
