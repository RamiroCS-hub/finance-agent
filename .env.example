# ============================================
# WhatsApp Meta Cloud API
# ============================================
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=mi_token_secreto
WHATSAPP_APP_SECRET=

# ============================================
# Google Sheets (solo para importación legacy)
# ============================================
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/service_account.json
GOOGLE_SPREADSHEET_ID=

# ============================================
# LLM Parser (proveedor intercambiable)
# ============================================
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
RECEIPT_OCR_PROVIDER=gemini
RECEIPT_OCR_MODEL=
RECEIPT_OCR_AUTO_CONFIDENCE=0.85
RECEIPT_OCR_CONFIRM_CONFIDENCE=0.60
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1

# ============================================
# Database
# Compatible con local Postgres o Supabase Postgres
# Si pegas una URL `postgresql://` o `postgres://`, la app la normaliza a asyncpg
# La base guarda timestamps en UTC
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/finance_bot
DATABASE_TIMEZONE=UTC

# ============================================
# App
# ============================================
DEFAULT_CURRENCY=ARS
GROUP_BOT_MENTION=@anotamelo
ALLOWED_PHONE_NUMBERS=
REDIS_URL=redis://localhost:6379/0
WHATSAPP_RATE_LIMIT_ENABLED=true
WHATSAPP_RATE_LIMIT_MAX_MESSAGES=8
WHATSAPP_RATE_LIMIT_WINDOW_SECONDS=60
WHATSAPP_RATE_LIMIT_NOTIFY_COOLDOWN_SECONDS=120
LLM_TIMEOUT_SECONDS=5
LOG_LEVEL=INFO

# ============================================
# Transcription (Groq Whisper)
# ============================================
GROQ_API_KEY=
TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# ============================================
# Agente
# ============================================
CONVERSATION_TTL_MINUTES=60
MAX_AGENT_ITERATIONS=10
MONTHLY_INFLATION_RATE=0
